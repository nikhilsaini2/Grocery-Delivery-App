# 🛒 Grocery Delivery App - Environment Variables Example
# Copy this file to '.env' and fill in the values for local development.

# Base API URL for product catalog, categories, and authentication endpoint
EXPO_PUBLIC_API_URL=https://dummyjson.com

# Optional Feature Flags
EXPO_PUBLIC_ENABLE_MOCK_PAYMENTS=true
EXPO_PUBLIC_DEBUG_MODE=false
